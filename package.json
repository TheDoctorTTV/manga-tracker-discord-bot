{
  "name": "discord-manga-tracker",
  "version": "1.0.0",
  "description": "A Discord bot that tracks manga updates from MangaDex for users.",
  "main": "src/app.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/app.js",
    "test": "node --test",
    "version:show": "node -e \"console.log(require('./version.json').version)\"",
    "version:set": "node scripts/set-version.js",
    "build:binary": "./scripts/build-binary.sh",
    "build:release": "./scripts/build-release-package.sh",
    "build:prerelease": "./scripts/build-prerelease-package.sh"
  },
  "dependencies": {
    "axios": "^1.8.2",
    "discord.js": "^14.18.0",
    "dotenv": "^16.4.7",
    "node-schedule": "^2.1.1"
  },
  "author": "TheDoctorTTV",
  "license": "MIT"
}
